# ── 기본 설정 ──────────────────────────────────────────────────────────────────
APP_USERNAME=admin
APP_PASSWORD=utlab1234
JWT_SECRET=change-this-secret-key

# ── Gemini AI ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_API_KEY2=
GEMINI_API_KEY3=
GEMINI_MODEL=gemini-2.5-flash

# ── Groq (Fallback) ────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Calendar 연동 ───────────────────────────────────────────────────────
# 1. Google Cloud Console에서 OAuth 2.0 클라이언트 ID 생성
#    https://console.cloud.google.com/ → API 및 서비스 → 사용자 인증 정보
#    애플리케이션 유형: 웹 애플리케이션
#    승인된 리디렉션 URI: https://your-domain.com/api/calendar/auth/callback

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/calendar/auth/callback

# 2. Push Notification 수신 URL (공개 HTTPS 필수)
#    Google이 이벤트 변경 시 이 URL로 즉시 POST 전송
#    미설정 시 30분 폴링으로 대체됨
GOOGLE_WEBHOOK_BASE_URL=https://your-domain.com

# 3. 토큰 암호화 키 (Fernet 32바이트 base64-urlsafe)
#    생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#    미설정 시 서버 재시작마다 새 키 생성 → 기존 토큰 복호화 불가 (재인증 필요)
CALENDAR_ENCRYPT_KEY=

# 4. 프론트엔드 URL (OAuth 콜백 후 리다이렉트)
FRONTEND_URL=https://your-domain.com

# ── KIS API (선택) ────────────────────────────────────────────────────────────
KIS_TAR_PATH=
KIS_BASE_URL=https://openapi.kiwoom.com
KIS_ACCOUNT_MAP=
